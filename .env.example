# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudflare Turnstile (optional in dev, required in production)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Backend API URL (leave empty for local dev — Vite proxy handles it)
# Set to your deployed backend URL in production, e.g. https://your-backend.onrender.com
VITE_API_URL=
